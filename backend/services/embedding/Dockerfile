FROM python:3.11-slim

WORKDIR /app

COPY services/embedding/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY shared/ shared/
COPY services/embedding/ services/embedding/

ENV PYTHONPATH=/app
EXPOSE 8002

CMD ["uvicorn", "services.embedding.app.main:app", "--host", "0.0.0.0", "--port", "8002"]
