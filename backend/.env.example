# Backend-focused env reference.
# For normal repo usage, prefer copying `/.env.example` to `/.env`.

# Local LLM
#LLM_URL=http://localhost:8080

# Host LLM
LLM_URL=http://host.docker.internal:8080

QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=documents
TOP_K=3
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
CHUNK_SIZE=800

# Reranker (optional: set to "none" or leave unset to disable)
RERANKER_PROVIDER=bge
VECTOR_SEARCH_TOP_K=20
RERANK_TOP_K=3

# Safeguard (input/output validation; set SAFEGUARD_ENABLED=false to disable)
SAFEGUARD_PROVIDER=basic
SAFEGUARD_ENABLED=true

# Optional ML service
ML_SERVICE_ENABLED=false
INJECTION_THRESHOLD=0.7
RETRIEVAL_SCORE_THRESHOLD=0.5

# Optional OpenAI backend settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
