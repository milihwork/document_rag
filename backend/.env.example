# Environment is loaded from the REPO ROOT, not from this file.
#
# Copy the root example and edit that:
#   cp /.env.example .env
# (from the repo root: document_rag/.env)
#
# All services (Python and Docker) use variables from the root .env when you
# run from the repo root. Docker Compose passes them via ${VAR:-default}.
#
# Docker-specific: if the LLM runs on your host (e.g. llama.cpp), set in root .env:
#   LLM_URL=http://host.docker.internal:8080
# For local (non-Docker) runs, use in root .env:
#   LLM_URL=http://localhost:8080
