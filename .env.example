# Local LLM
#LLM_URL=http://localhost:8080

# Host LLM
LLM_URL=http://host.docker.internal:8080

# Embedding service (sentence-transformers / Hugging Face local backend)
# Recommended explicit backend name (alias: local)
EMBEDDING_BACKEND=huggingface
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Normalize embeddings (recommended for cosine similarity).
# Changing EMBEDDING_MODEL or EMBEDDING_NORMALIZE requires re-embedding stored vectors.
EMBEDDING_NORMALIZE=true

# Optional performance knobs
#EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
#EMBEDDING_MAX_LENGTH=512

COLLECTION_NAME=documents
TOP_K=3
CHUNK_SIZE=800

# Optional retrieval quality settings
RERANKER_PROVIDER=bge
VECTOR_SEARCH_TOP_K=20
RERANK_TOP_K=3

# Optional safeguards
SAFEGUARD_PROVIDER=basic
SAFEGUARD_ENABLED=true

# Optional ML service
ML_SERVICE_ENABLED=false
INJECTION_THRESHOLD=0.7
RETRIEVAL_SCORE_THRESHOLD=0.5

# Optional LangChain orchestration (RAG service)
# Enable a feature-flagged LangChain retrieval path inside the RAG service.
# This keeps the existing architecture (Embedding + Retrieval services over HTTP) unchanged.
LANGCHAIN_ENABLED=false

# Multi-query retrieval (generates N query variants and merges/dedupes results)
MULTIQUERY_ENABLED=true
MULTIQUERY_N=4

# Candidate depth fetched per query variant (pre-rerank). Useful when reranking is enabled.
# Defaults to VECTOR_SEARCH_TOP_K if not set.
#LANGCHAIN_RETRIEVER_TOP_K=20
#If you want everything LangChain/LangSmith-related effectively “off”, set:
#LANGCHAIN_ENABLED=false
#LANGSMITH_TRACING=false


# Optional LangSmith tracing
# If true, the RAG service will set LANGCHAIN_TRACING_V2=true automatically.
# To actually send traces to LangSmith, also set the standard LangChain/LangSmith env vars:
# - LANGCHAIN_API_KEY
# - LANGCHAIN_PROJECT (or LANGSMITH_PROJECT)
# - LANGCHAIN_ENDPOINT (optional; defaults to LangSmith cloud)
LANGSMITH_TRACING=false
#LANGCHAIN_API_KEY=
#LANGCHAIN_PROJECT=document_rag

# Optional OpenAI backend settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
